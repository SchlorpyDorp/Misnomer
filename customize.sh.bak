#!/system/bin/sh

ui_print " "
ui_print "================================="
ui_print "         Misnomer v1.0"
ui_print "================================="
ui_print " "
ui_print "- Installing module..."
ui_print "- Creating configuration..."
ui_print " "

mkdir -p "$MODPATH/config"

if [ ! -f "$MODPATH/config/props.conf" ]; then
cat > "$MODPATH/config/props.conf" << EOF
MODEL=
BRAND=
MANUFACTURER=
DEVICE=
NAME=
PRODUCT=
EOF
fi

ui_print "- Done!"
ui_print " "